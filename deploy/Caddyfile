# Caddy blocks for StreamMulti: streammulti.live is production; multistream.
# robertmckinnon.au is kept running as a dev/staging site (e.g. for testing
# Twitch OAuth and the HLS proxy against a real deployed domain instead of
# localhost) -- both point at the same `multistream` container.
#
# The handbook keeps ONE shared Caddyfile at /opt/workout/Caddyfile. The deploy
# workflow splices THIS block into it automatically (marker-delimited,
# idempotent) then validates + reloads Caddy -- no manual edit needed. The
# (security) snippet (HSTS) is already defined at the top of that shared file.
# Caddy auto-issues its own Let's Encrypt cert here regardless of which
# registrar/domain this is -- no extra TLS setup needed once DNS resolves.
#
# /api/hls-proxy* is routed to the Go hlsproxy sidecar instead of the Pyramid
# app on both domains; everything else still goes to `multistream`. The
# frontend's path contract (/api/hls-proxy?url=...) is unchanged, so this
# split is invisible to the browser -- only the backend selection moved.

streammulti.live {
  import security
  encode gzip
  handle /api/hls-proxy* {
    reverse_proxy hlsproxy:8080
  }
  handle {
    reverse_proxy multistream:6543
  }
}

multistream.robertmckinnon.au {
  import security
  encode gzip
  handle /api/hls-proxy* {
    reverse_proxy hlsproxy:8080
  }
  handle {
    reverse_proxy multistream:6543
  }
}
