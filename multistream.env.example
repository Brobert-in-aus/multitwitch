# Copy to /etc/multistream.env on the VPS (chmod 600). Commit this example only —
# never real secrets. Loaded by deploy/docker-compose.yml via env_file.

# --- Twitch OAuth (app works read-only without these; follows/Stream Together
#     stay disabled until a viewer connects) ---
# Register a Twitch application and set its OAuth redirect URL to:
#   https://multistream.robertmckinnon.au/auth/twitch/callback
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# Redirect URI + secure cookies + DB path are pinned in docker-compose.yml, but
# can be overridden here if needed:
# TWITCH_REDIRECT_URI=https://multistream.robertmckinnon.au/auth/twitch/callback
# TWITCH_SECURE_COOKIES=1
# TWITCH_SESSION_DB=/app/data/multistream.sqlite3

# --- Litestream -> Backblaze B2 (SQLite session DB backup) ---
# Reuse the same B2 credentials as other tools; the replica path ("multistream")
# is already set uniquely in litestream.yml. Set all five to enable replication;
# leave blank to run without backups.
LITESTREAM_ACCESS_KEY_ID=
LITESTREAM_SECRET_ACCESS_KEY=
LITESTREAM_BUCKET=
LITESTREAM_ENDPOINT=
LITESTREAM_REGION=
