# Copy to /etc/multistream.env on the VPS (chmod 600). Commit this example only —
# never real secrets. Loaded by deploy/docker-compose.yml via env_file.

# --- Twitch OAuth (direct playback and Stream Together work without this;
#     follows, authenticated metadata, and go-live notifications require it) ---
# Register a Twitch application with BOTH of these as registered OAuth
# redirect URLs (Twitch allows multiple per app):
#   https://streammulti.live/auth/twitch/callback
#   https://multistream.robertmckinnon.au/auth/twitch/callback
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# Secure cookies + DB path are pinned in docker-compose.yml, but can be
# overridden here if needed:
# TWITCH_SECURE_COOKIES=1
# TWITCH_SESSION_DB=/app/data/multistream.sqlite3
# TWITCH_REDIRECT_URI is intentionally NOT pinned -- it's derived per-request
# from whichever domain the visitor used (see README's Deployment section).
# Only set this if you want every domain to redirect through one fixed URL:
# TWITCH_REDIRECT_URI=https://streammulti.live/auth/twitch/callback

# --- Litestream -> Backblaze B2 (SQLite session DB backup) ---
# Reuse the same B2 credentials as other tools; the replica path ("multistream")
# is already set uniquely in litestream.yml. Set all five to enable replication;
# leave blank to run without backups.
LITESTREAM_ACCESS_KEY_ID=
LITESTREAM_SECRET_ACCESS_KEY=
LITESTREAM_BUCKET=
LITESTREAM_ENDPOINT=
LITESTREAM_REGION=

# --- Feedback form (the "Feedback" button under the title) ---
# Sends via Resend's HTTP API. The visitor never sees feedback@robertmckinnon.au
# anywhere in the page or in API responses -- it's only the From address; replies
# go straight to your inbox via Reply-To if the visitor leaves their email.
# Reuse the same Resend account/API key as other robertmckinnon.au tools (the
# robertmckinnon.au domain must already be verified for sending in Resend).
RESEND_API_KEY=
# Where feedback submissions are delivered. Required -- there's no default.
FEEDBACK_TO=
# Optional override; defaults to "StreamMulti Feedback <feedback@robertmckinnon.au>".
# FEEDBACK_FROM=

# --- Lightweight usage events ---
# Defaults to daily files like /app/data/usage-events-2026-06-25.jsonl in
# docker-compose.yml. Events are first-party JSON lines with coarse UI state
# only: no IPs, cookies, Twitch channel names, full URLs, or playlist tokens.
# ANALYTICS_LOG_FILE=/app/data/usage-events.jsonl
# ANALYTICS_RETENTION_DAYS=30
